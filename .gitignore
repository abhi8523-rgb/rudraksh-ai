# ----- Environment & Secrets -----
.env
.env.local
.env.*.local
*.pem
*.key

# ----- Python -----
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
*.whl
.venv/
venv/
env/
.pytest_cache/
.mypy_cache/
.ruff_cache/
htmlcov/
.coverage
coverage.xml

# ----- Node.js / Next.js -----
node_modules/
.next/
out/
.turbo/
*.tsbuildinfo
next-env.d.ts

# ----- Docker -----
docker-compose.override.yml

# ----- Data & Storage -----
chroma_data/
uploads/
*.sqlite
*.db
audit_logs/

# ----- IDE -----
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ----- Ollama Models (too large for git) -----
ollama_data/

# ----- Logs -----
*.log
logs/
