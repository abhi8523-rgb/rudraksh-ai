# ============================================================
# Neel AI — Environment Configuration
# ============================================================
# Copy this file to .env and update the values.
# Variables prefixed with NEEL_ are loaded by the backend.
# ============================================================

# ── Backend Server ──────────────────────────────────────────
NEEL_HOST=0.0.0.0
NEEL_PORT=8001
NEEL_DEBUG=true
NEEL_ENVIRONMENT=development

# ── Ollama (Local LLM) ─────────────────────────────────────
NEEL_OLLAMA_BASE_URL=http://localhost:11434
NEEL_OLLAMA_DEFAULT_MODEL=llama3.2:3b
NEEL_OLLAMA_EMBED_MODEL=nomic-embed-text
NEEL_OLLAMA_TIMEOUT=120.0
NEEL_OLLAMA_MAX_TOKENS=2048

# ── LM Studio ──────────────────────────────────────────────
NEEL_LMSTUDIO_BASE_URL=http://localhost:1234/v1
NEEL_LMSTUDIO_DEFAULT_MODEL=default

# ── ChromaDB (Vector Memory) ───────────────────────────────
NEEL_CHROMA_HOST=localhost
NEEL_CHROMA_PORT=8100
NEEL_CHROMA_DEFAULT_COLLECTION=neel_memory

# ── JWT Authentication ──────────────────────────────────────
NEEL_JWT_SECRET_KEY=neel-ai-change-me-in-production-2026
NEEL_JWT_ALGORITHM=HS256
NEEL_JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── Storage ─────────────────────────────────────────────────
NEEL_UPLOAD_DIR=data/uploads
NEEL_SQLITE_DB_PATH=data/db/neel_audit.db

# ── Trident Engine ──────────────────────────────────────────
NEEL_TRIDENT_MAX_ITERATIONS=10
NEEL_TRIDENT_SANDBOX_TIMEOUT=30
NEEL_TRIDENT_SANDBOX_DIR=data/sandbox

# ── Docker Compose Ports ────────────────────────────────────
BACKEND_PORT=8001
FRONTEND_PORT=3000

# ── Frontend ────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8001
